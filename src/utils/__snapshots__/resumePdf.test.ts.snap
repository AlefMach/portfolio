// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`buildResumeTemplate > matches the resume PDF layout contract 1`] = `
"<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Resume Alef Machado</title>
    <style>
      @page {
        margin: 12mm;
        size: A4;
      }

      * {
        box-sizing: border-box;
      }

      body {
        background: #eef1f4;
        color: #1f2933;
        font-family: Arial, Helvetica, sans-serif;
        line-height: 1.45;
        margin: 0;
      }

      .resume {
        background: #ffffff;
        display: grid;
        grid-template-columns: 210px 1fr;
        margin: 0 auto;
        min-height: 297mm;
        width: 210mm;
      }

      aside {
        background: #17212f;
        color: #eef4f8;
        padding: 28px 22px;
      }

      main {
        padding: 30px 34px;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        color: #111827;
        font-size: 32px;
        letter-spacing: 0;
        line-height: 1.05;
      }

      .role {
        color: #0f766e;
        font-size: 15px;
        font-weight: 700;
        margin-top: 8px;
      }

      .tagline {
        color: #4b5563;
        font-size: 12px;
        margin-top: 8px;
      }

      section {
        margin-top: 24px;
      }

      h2 {
        border-bottom: 1px solid #d6dde5;
        color: #111827;
        font-size: 13px;
        letter-spacing: 0.08em;
        padding-bottom: 6px;
        text-transform: uppercase;
      }

      aside h2 {
        border-color: rgba(255, 255, 255, 0.18);
        color: #ffffff;
      }

      .contact-list,
      ul {
        list-style: none;
        margin: 12px 0 0;
        padding: 0;
      }

      .contact-list li,
      aside p,
      aside a {
        color: #d7e0e8;
        font-size: 11px;
        overflow-wrap: anywhere;
        text-decoration: none;
      }

      .contact-list li + li {
        margin-top: 8px;
      }

      .qr {
        background: #ffffff;
        border-radius: 6px;
        display: block;
        height: 132px;
        margin-top: 12px;
        padding: 8px;
        width: 132px;
      }

      .pill-list {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-top: 12px;
      }

      .pill {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 999px;
        color: #f8fafc;
        font-size: 10px;
        padding: 5px 8px;
      }

      .summary {
        color: #374151;
        font-size: 12px;
        margin-top: 12px;
      }

      .item {
        break-inside: avoid;
        margin-top: 14px;
      }

      .item-heading {
        align-items: baseline;
        display: flex;
        gap: 12px;
        justify-content: space-between;
      }

      .item h3 {
        color: #111827;
        font-size: 13px;
      }

      .item-heading span,
      .company {
        color: #64748b;
        font-size: 11px;
        white-space: nowrap;
      }

      .company {
        color: #0f766e;
        font-weight: 700;
        margin-top: 2px;
      }

      main ul {
        display: grid;
        gap: 3px;
        list-style: disc;
        margin-top: 7px;
        padding-left: 18px;
      }

      main li,
      .item p,
      .stack-row {
        color: #374151;
        font-size: 11px;
      }

      .compact p {
        margin-top: 5px;
      }

      .stack-row {
        border-bottom: 1px solid #edf1f5;
        display: grid;
        gap: 8px;
        grid-template-columns: 104px 1fr;
        padding: 8px 0;
      }

      .stack-row strong {
        color: #111827;
      }

      .print-note {
        color: #64748b;
        font-size: 10px;
        margin-top: 8px;
      }

      @media print {
        body {
          background: #ffffff;
        }

        .resume {
          margin: 0;
          min-height: auto;
          width: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="resume">
      <aside>
        <section>
          <h2>Contatos</h2>
          <ul class="contact-list">
            <li>alef_mac@hotmail.com</li>
            <li>https://www.linkedin.com/in/alef-machado/</li>
            <li>https://github.com/AlefMach</li>
            <li>Brasil / remoto</li>
          </ul>
        </section>

        <section>
          <h2>Portfolio</h2>
          <img class="qr" src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&margin=8&data=https%3A%2F%2Falefmach.github.io%2Fportfolio%2F%23home" alt="QR Code" />
          <p class="print-note">https://alefmach.github.io/portfolio/#home</p>
        </section>

        <section>
          <h2>Destaques</h2>
          <div class="pill-list">
            <span class="pill">High Availability</span><span class="pill">Distributed Systems</span><span class="pill">Payments &amp; Fintech</span><span class="pill">Cloud Native</span><span class="pill">Observability</span><span class="pill">AI Automation</span>
          </div>
        </section>
      </aside>

      <main>
        <header>
          <h1>Alef Machado</h1>
          <p class="role">Backend Software Engineer</p>
          <p class="tagline">Fintech • Pagamentos • Sistemas Distribuídos • Automação com IA</p>
        </header>

        <section>
          <h2>Sobre mim</h2>
          <p class="summary">Construo e opero software backend para ambientes onde disponibilidade, rastreabilidade e evolução técnica impactam diretamente o negócio.</p>
          <p class="summary">Minha experiência passa por sistemas de contas, pagamentos, integrações, mensageria, deploys, QA, monitoramento e infraestrutura. Trabalho com Elixir, Kotlin, Kubernetes, cloud-native, observabilidade e automações com IA para reduzir trabalho manual e aumentar previsibilidade operacional.</p>
        </section>

        <section>
          <h2>Experiências</h2>
          
        <article class="item">
          <div class="item-heading">
            <h3>Software Engineer</h3>
            <span>2025 - Atual</span>
          </div>
          <p class="company">Swap</p>
          <ul><li>Plataforma de contas e pagamentos</li><li>APIs críticas de movimentação financeira</li><li>Observabilidade e monitoração</li><li>Operações críticas 24/7</li><li>Processando milhares de transações por dia</li></ul>
        </article>
      
        <article class="item">
          <div class="item-heading">
            <h3>Software Engineer</h3>
            <span>2024 - 2025</span>
          </div>
          <p class="company">Ghisolfi</p>
          <ul><li>Sistemas internos</li><li>Integrações</li><li>Infraestrutura</li><li>Escala para milhares de usuários</li></ul>
        </article>
      
        <article class="item">
          <div class="item-heading">
            <h3>Software Engineer</h3>
            <span>2022 - 2023</span>
          </div>
          <p class="company">Solfácil</p>
          <ul><li>Métodos de pagamento</li><li>Backend e frontend</li><li>QA</li><li>Deploys</li><li>Monitoramento</li></ul>
        </article>
      
        <article class="item">
          <div class="item-heading">
            <h3>Software Engineer</h3>
            <span>2021 - 2022</span>
          </div>
          <p class="company">Alertrack</p>
          <ul><li>Backend e frontend</li><li>QA</li><li>Deploys</li><li>Monitoramento</li><li>Build system do zero</li></ul>
        </article>
      
        </section>

        <section>
          <h2>Stack</h2>
          
        <div class="stack-row">
          <strong>Frontend</strong>
          <span>React, TypeScript, Material UI</span>
        </div>
      
        <div class="stack-row">
          <strong>Backend</strong>
          <span>Node.js, Elixir, Kotlin, Python, Go, APIs, Mensageria, Arquitetura orientada a eventos</span>
        </div>
      
        <div class="stack-row">
          <strong>Banco de Dados</strong>
          <span>PostgreSQL, SqlServer, Cassandra, MongoDB, Redis</span>
        </div>
      
        <div class="stack-row">
          <strong>Cloud</strong>
          <span>AWS, Docker, CI/CD, Kubernetes, Terraform</span>
        </div>
      
        <div class="stack-row">
          <strong>Observabilidade</strong>
          <span>OpenTelemetry, Logs, Métricas, Tracing</span>
        </div>
      
        <div class="stack-row">
          <strong>IA e Automação</strong>
          <span>n8n, LLMs, RAG, Slack</span>
        </div>
      
        </section>

        <section>
          <h2>Casos de engenharia selecionados</h2>
          
        <article class="item compact">
          <h3>Automação Inteligente de Triagem e Fluxo de Desenvolvimento</h3>
          <p>n8n • IA • Slack • Git Workflow Automation. Automação criada para classificar demandas, integrar sistemas internos e reduzir etapas manuais no fluxo operacional e de desenvolvimento.</p>
        </article>
      
        <article class="item compact">
          <h3>Think Cloud</h3>
          <p>Plataforma para comparar custos cloud e apoiar decisões de FinOps. A solução organiza benchmarks e indicadores em dashboards, dando mais clareza para análises técnicas e comerciais.</p>
        </article>
      
        <article class="item compact">
          <h3>Webhooks e Notificações • Swap</h3>
          <p>Sistema de mensageria para alto volume de webhooks e notificações. O trabalho deu visibilidade ao fluxo real de mensagens por quantidade, URL e realm, expondo gargalos que antes ficavam invisíveis na aplicação.</p>
        </article>
      
        <article class="item compact">
          <h3>Bots Conversacionais • Alertrack</h3>
          <p>Plataforma de bots conversacionais para atendimento e comunicação em tempo real via WhatsApp, conectando mensagens, regras de negócio, webhooks e automações externas.</p>
        </article>
      
        </section>
      </main>
    </div>
  </body>
</html>"
